@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center min-vh-75">

        <div class="col-lg-8 text-center">

            <span class="badge rounded-pill text-bg-primary px-3 py-2 mb-4">
                 Organize seus medicamentos
            </span>

            <h1 class="display-2 fw-bold mb-4">
                Controle de
                <span class="text-primary">Medicamentos</span>
            </h1>

            <p class="lead text-secondary mb-5">
                Gerencie seus medicamentos com praticidade,
                acompanhe quantidades e mantenha tudo organizado em um único lugar.
            </p>

            <a class="btn btn-primary btn-lg px-5 shadow"
               asp-controller="CentroControle"
               asp-action="Listar">
                Centro de Controle
            </a>

        </div>

    </div>
</div>