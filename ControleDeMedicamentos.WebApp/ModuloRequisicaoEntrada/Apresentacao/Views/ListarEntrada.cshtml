@{
    Layout = "_Layout";
}

@model List<ListarRequisicaoEntradaViewModel>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Consulta de Requisições de Entrada</h2>
        <a type="button" class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="CadastrarEntrada">
            <i class="bi bi-plus-lg me-2"></i>Nova Requisição</a>
    </div>

@if (Model.Count == 0)
{
    <div class="alert alert-warning 12px" role="alert">
        Nenhuma Requisção de Entrada cadastrada!
    </div>
}

</div>
