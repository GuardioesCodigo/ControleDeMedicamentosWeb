@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Controle de Estoque</h1>
        <p class="lead text-muted">
            Selecione a operação que deseja realizar.
        </p>
    </div>

    <div class="row justify-content-center g-4">

        <div class="col-md-6 col-lg-5">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column text-center p-5">

                    <div class="mb-4">
                        <i class="bi bi-box-arrow-in-down display-3 text-success"></i>
                    </div>

                    <h3 class="card-title mb-3">
                        Requisição de Entrada
                    </h3>

                    <p class="card-text text-muted flex-grow-1">
                        Registre a entrada de medicamentos no estoque,
                        atualizando as quantidades disponíveis.
                    </p>

                    <a asp-controller="RequisicaoEntrada"
                        asp-action="ListarEntrada"
                        class="btn btn-success btn-lg rounded-pill mt-3"> Acessar Entradas</a>

                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-5">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column text-center p-5">

                    <div class="mb-4">
                        <i class="bi bi-box-arrow-up display-3 text-danger"></i>
                    </div>

                    <h3 class="card-title mb-3">
                        Requisição de Saída
                    </h3>

                    <p class="card-text text-muted flex-grow-1">
                        Registre a saída de medicamentos do estoque,
                        controlando as movimentações realizadas.
                    </p>

                    <a asp-controller="Estoque"
                        asp-action="ListarSaida"
                        class="btn btn-danger btn-lg rounded-pill mt-3">Acessar Saídas</a>

                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-5">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column text-center p-5">

                    <div class="mb-4">
                        <i class="bi bi-clock-history display-3 text-primary"></i>
                    </div>

                    <h3 class="card-title mb-3">
                        Histórico de Movimentações
                    </h3>

                    <p class="card-text text-muted flex-grow-1">
                        Consulte todas as entradas e saídas realizadas no estoque.
                    </p>

                    <a asp-controller="Estoque"
                        asp-action="ListarMovimentacoes"
                    class="btn btn-primary btn-lg rounded-pill mt-3">
                        Ver Histórico
                    </a>

                </div>
            </div>
        </div>

    </div>
</div>