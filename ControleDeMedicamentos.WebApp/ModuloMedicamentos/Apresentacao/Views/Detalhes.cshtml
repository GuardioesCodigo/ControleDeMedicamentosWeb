@{
    Layout = "_Layout";
}

@model DetalhesMedicamentosViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <div class="card border-0 shadow-lg p-4 rounded-4 w-100"
         style="max-width: 620px;">

        <h2>Detalhes do Medicamento</h2>

        <div class="mb-4">
            <label class="form-label fw-semibold">Nome</label>
            <input type="text"
                    class="form-control form-control-lg rounded-3 shadow-sm"
                    value="@Model.Nome"
                    readonly>
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Descrição</label>
            <textarea class="form-control rounded-3 shadow-sm"
                    rows="5"
                    readonly>@Model.Descricao</textarea>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-primary text-uppercase small">Quantidade</label>

            <input type="text"
                   class="form-control"
                   value="@Model.Quantidade"
                   readonly>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-primary text-uppercase small">Fornecedor</label>

            <input type="text"
                class="form-control"
                value="@Model.FornecedorNome"
                readonly>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">

            <a class="btn btn-outline-danger rounded-pill"
               asp-action="Listar">Voltar</a>

            <a class="btn btn-outline-secondary rounded-pill"
               asp-action="Editar"
               asp-route-id="@Model.Id">Editar</a>

        </div>
    </div>
</div>