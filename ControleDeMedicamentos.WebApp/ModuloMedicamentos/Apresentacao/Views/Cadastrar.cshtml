@{
    Layout = "_Layout";
}

@model CadastrarMedicamentosViewModel

@if (Model.Fornecedores.Count == 0)
{
    <div class="alert alert-warning 12px" role="alert;">
        Cadastre um Fornecedor antes de cadastrar um Medicamento.
    </div>
}

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
        style="max-width: 620px;"
        asp-action="Cadastrar"
        method="post">
          
        <h2>Cadastro de Medicamentos</h2>

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Descricao" class="form-label fw-semibold">Descricao</label>
            <input asp-for="Descricao" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Descricao" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Quantidade" class="form-label fw-semibold text-primary text-uppercase small">Quantidade</label>
            <input asp-for="Quantidade" type="number" min="1" step="1" class="form-control">
            <span asp-validation-for="Quantidade" class="text-danger small fw-semibold"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FornecedorId" class="form-label fw-semibold text-primary text-uppercase small">Fornecedor</label>
            <select asp-for="FornecedorId" class="form-select">
                <option value="">Selecione um Fornecedor</option>
                @foreach (OpcaoFornecedoresViewModel fornecedores in Model.Fornecedores)
                {
                    <option value="@fornecedores.Id">@fornecedores.Nome</option>
                }
            </select>
            <span asp-validation-for="FornecedorId" class="text-danger small fw-semibold"></span>
        </div>


         <div class="d-flex justify-content-end gap-3 mt-4">

            <div class="d-flex justify-content-end gap-2 mt-4">
                
                <a class="btn btn-outline-danger rounded-pill" asp-action="Listar">Voltar</a>

                <button class="btn btn-outline-success rounded-pill" type="submit">Confirmar</button>

            </div>

        </div>
    </form>

</div>
