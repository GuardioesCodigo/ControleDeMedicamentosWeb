@{
    Layout = "_Layout";
}

@model IEnumerable<ListarPacienteViewModel>
@using ControleDeMedicamentos.WebApp.ModuloPacientes.Views

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Consulta de Pacientes</h2>
    
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Cadastrar">
            <i class="bi bi-plus-lg me-2"></i>Novo Paciente
        </a>
    </div>

    @* CORREÇÃO AQUI: Adicionado os parênteses no Count() *@
    @if (Model == null || Model.Count() == 0)
    {
        <div class="alert alert-warning" role="alert">
            Nenhum Paciente cadastrado!
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm rounded-3">
                <thead class="table-primary">
                    <tr>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Cartão SUS</th>
                        <th>CPF</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Nome</td>
                            <td>@p.Telefone</td>
                            <td>@p.CartaoSus</td>
                            <td>@p.CPF</td>
                            <td class="text-center">
                                <a class="btn btn-outline-secondary rounded-pill px-3" asp-action="Editar" asp-route-id="@p.Id">Editar</a>
                                <a class="btn btn-outline-danger rounded-pill px-3" asp-action="Excluir" asp-route-id="@p.Id">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>