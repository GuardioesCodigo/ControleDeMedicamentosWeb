@{
    ViewData["Title"] = "Cadastrar Funcionário";
    Layout = "_Layout";
}

@model ControleDeMedicamentos.WebApp.ModuloFuncionarios.Apresentacao.FuncionarioViewModel

<div class="container d-flex justify-content-center align-items-center" 
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100" 
          style="max-width: 620px;"
          asp-controller="Funcionarios" 
          asp-action="Cadastrar" 
          method="post">

        @Html.AntiForgeryToken()

        <h2 class="mb-4">Cadastro de Funcionário</h2>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome Completo</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Telefone" class="form-label fw-semibold">Telefone</label>
            <input asp-for="Telefone" id="Telefone" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Telefone" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Cpf" class="form-label fw-semibold">CPF</label>
            <input asp-for="Cpf" id="Cpf" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Cpf" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a class="btn btn-outline-danger rounded-pill px-4" asp-controller="Funcionarios" asp-action="Listar">
                Voltar
            </a>
            <button type="submit" class="btn btn-outline-success rounded-pill px-4">
                Confirmar
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.17.0/jquery.validate.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validation.unobtrusive/3.2.10/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function(){
            $('#Telefone').mask('(00) 00000-0000');
            $('#Cpf').mask('000.000.000-00');
            
            $('form').submit(function() {
                $('#Telefone').unmask();
                $('#Cpf').unmask();
            });
        });
    </script>
}