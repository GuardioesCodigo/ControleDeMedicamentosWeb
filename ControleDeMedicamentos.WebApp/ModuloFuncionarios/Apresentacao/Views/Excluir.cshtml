@model ControleDeMedicamentos.WebApp.ModuloFuncionarios.Apresentacao.ExcluirFuncionarioViewModel

@{
    ViewData["Title"] = "Excluir Funcionário";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Excluir Funcionário</h4>
        </div>
        <div class="card-body p-4">
            <p class="lead">Tem certeza que deseja excluir o funcionário?</p>
            
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="fw-bold">Nome:</label>
                    <p class="form-control-static">@Model.Nome</p>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Telefone:</label>
                    <p class="form-control-static">@Model.Telefone</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">CPF:</label>
                    <p class="form-control-static">@Model.CPF</p>
                </div>
            </div>

            <form asp-action="Excluir" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 me-2">Cancelar</a>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Confirmar Exclusão</button>
                </div>
            </form>
        </div>
    </div>
</div>