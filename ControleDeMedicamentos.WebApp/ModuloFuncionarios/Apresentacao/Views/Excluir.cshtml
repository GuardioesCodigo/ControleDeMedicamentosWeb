@{
    ViewData["Title"] = "Excluir Funcionário";
    Layout = "_Layout";
}

@model ControleDeMedicamentos.WebApp.ModuloFuncionarios.Apresentacao.ExcluirFuncionarioViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
          style="max-width: 620px;"
          asp-controller="Funcionarios"
          asp-action="Excluir"
          asp-route-id="@Model.Id"
          method="post">

        <input asp-for="Id" type="hidden">

        <h2 class="mb-4">Exclusão de Funcionário</h2>

        <div class="alert alert-warning" role="alert">
            Deseja realmente excluir este funcionário?
        </div>

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome Completo</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm" readonly>
        </div>

        <div class="mb-4">
            <label asp-for="Telefone" class="form-label fw-semibold">Telefone</label>
            <input asp-for="Telefone" type="text" class="form-control form-control-lg rounded-3 shadow-sm" readonly>
        </div>

        <div class="mb-4">
            <label asp-for="CPF" class="form-label fw-semibold">CPF</label>
            <input asp-for="CPF" type="text" class="form-control form-control-lg rounded-3 shadow-sm" readonly>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a class="btn btn-outline-secondary rounded-pill px-4" asp-controller="Funcionarios" asp-action="Listar">
                Voltar
            </a>
            <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                Excluir
            </button>
        </div>
    </form>
</div>