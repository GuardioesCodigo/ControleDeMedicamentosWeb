@model ControleDeMedicamentos.WebApp.ModuloFuncionarios.Apresentacao.EditarFuncionarioViewModel

@{
    ViewData["Title"] = "Editar Funcionário";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Editar Funcionário</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Editar" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2"></div>
                
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome Completo</label>
                    <input asp-for="Nome" class="form-control rounded-pill" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefone" class="form-label">Telefone</label>
                        <input asp-for="Telefone" class="form-control rounded-pill" placeholder="(00) 00000-0000"/>
                        <span asp-validation-for="Telefone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cpf" class="form-label">CPF</label>
                        <input asp-for="Cpf" class="form-control rounded-pill" />
                        <span asp-validation-for="Cpf" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 me-2">Cancelar</a>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">Salvar Alterações</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.17.0/jquery.validate.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validation.unobtrusive/3.2.10/jquery.validate.unobtrusive.min.js"></script>

    <script>
        $(document).ready(function(){
            // Aplica as máscaras
            $('#Telefone').mask('(00) 00000-0000');
            $('#Cpf').mask('000.000.000-00'); // Ajuste o formato se necessário
            
            // Remove as máscaras antes de enviar para o servidor
            $('form').submit(function() {
                $('#Telefone').unmask();
                $('#Cpf').unmask();
            });
        });
    </script>
}