@model ControleDeMedicamentos.WebApp.ModuloPacientes.Views.PacienteViewModel
@using ControleDeMedicamentos.WebApp.ModuloPacientes.Views
<form asp-action="Cadastrar" method="post">
    <div>
        <label>Nome:</label>
        <input asp-for="Nome" class="form-control" />
    </div>
    <div>
        <label>Telefone:</label>
        <input asp-for="Telefone" class="form-control" />
    </div>
    <div>
        <label>Cartão SUS:</label>
        <input asp-for="CartaoSus" class="form-control" />
    </div>
    <div>
        <label>CPF:</label>
        <input asp-for="CPF" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Salvar</button>
</form>