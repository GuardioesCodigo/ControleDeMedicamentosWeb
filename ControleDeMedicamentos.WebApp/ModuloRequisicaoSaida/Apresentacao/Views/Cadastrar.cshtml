@model ControleDeMedicamentosWeb.WebApp.ModuloRequisicaoSaida.Apresentacao.CadastrarRequisicaoSaidaViewModel

@{ Layout = "_Layout"; }

<div class="container d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 120px);">
    <form class="card border-0 shadow-lg p-4 rounded-4 w-100" style="max-width: 620px;" asp-action="Cadastrar" method="post">
        
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

        <h2 class="mb-4">Cadastro de Requisição de Saída</h2>

        <div class="mb-3">
            <label asp-for="Data" class="form-label fw-semibold text-primary text-uppercase small">Data</label>
            <input asp-for="Data" type="date" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="PacienteId" class="form-label fw-semibold text-primary text-uppercase small">Paciente</label>
            <select asp-for="PacienteId" asp-items="Model.Pacientes" class="form-select">
                <option value="">Selecione um Paciente</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-primary text-uppercase small">Medicamentos</label>
            <div id="lista-itens" class="border p-3 rounded bg-light mb-2"></div>
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="adicionarMedicamento()">
                + Adicionar Medicamento
            </button>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-danger rounded-pill" asp-action="Listar">Voltar</a>
            <button class="btn btn-outline-success rounded-pill" type="submit">Confirmar</button>
        </div>
    </form>
</div>

<script>
    let contador = 0;
    function adicionarMedicamento() {
        let container = document.getElementById('lista-itens');
        let div = document.createElement('div');
        div.className = 'row mb-2 align-items-center';
        div.innerHTML = `
            <div class="col-7">
                <select name="Itens[${contador}].MedicamentoId" class="form-select form-select-sm">
                    @foreach(var m in Model.Medicamentos) {
                        <option value="@m.Value">@m.Text</option>
                    }
                </select>
            </div>
            <div class="col-3">
                <input name="Itens[${contador}].Quantidade" type="number" value="1" class="form-control form-control-sm" />
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.parentElement.remove()">X</button>
            </div>
        `;
        container.appendChild(div);
        contador++;
    }
</script>